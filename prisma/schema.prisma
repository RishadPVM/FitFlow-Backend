generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum DeviceType {
  ANDROID
  IOS
}

enum BloodGroup {
  aPositive
  aNegative
  bPositive
  bNegative
  abPositive
  abNegative
  oPositive
  oNegative
}

enum Gender {
  male
  female
  other
}

enum GymStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
  REJECTED
  CLOSED
}

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  phone        String? @unique
  profileImage String?
  profileImageKey String?
  googleId     String? @unique

  deviceType    DeviceType
  bloodGroup    BloodGroup?
  dateOfBirth   DateTime?
  isActive      Boolean     @default(true)
  currentWeight Float?
  targetWeight  Float?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  gender        Gender?
  height        Float?

  currentMembershipPlan   UserMembershipPlans? @relation("CurrentMembership", fields: [currentMembershipPlanId], references: [id])
  currentMembershipPlanId String?

  gym   Gym?    @relation(fields: [gymId], references: [id])
  gymId String?

  isBlocked Boolean @default(false)

  userMembershipPlans UserMembershipPlans[] @relation("UserMembershipHistory")


  attendances Attendance[]
  chatParticipants Participant[]
  lastSeen         DateTime?
  isOnline         Boolean @default(false)

  weightLogs   WeightLog[]
  targetLogs   TargetLog[]
}

model Gym {
  id              String  @id @default(uuid())
  gymCode         String  @unique
  gymName         String
  ownerName       String
  gymAbout        String? @db.Text
  establishedYear Int?

  email          String  @unique
  phone          String  @unique
  whatsappNumber String?
  alternatePhone String?
  website        String?

  address    String
  city       String
  district   String?
  state      String
  country    String   @default("India")
  postalCode String
  latitude   Decimal? @db.Decimal(10, 7)
  longitude  Decimal? @db.Decimal(10, 7)

  workingHours Json? // Example: {"monday":{"open":"05:00","close":"22:00"}}
  is24Hours    Boolean @default(false)

  logoUrl       String?
  logoKey       String?
  coverImageUrl String?
  coverImageKey String?

  currency       String @default("INR")
  timezone       String @default("Asia/Kolkata")
  maxMembers     Int?
  currentMembers Int    @default(0)

  instagramUrl String?
  facebookUrl  String?
  youtubeUrl   String?

  status     GymStatus @default(PENDING)
  isActive   Boolean   @default(false)
  isVerified Boolean   @default(false)
  isFeatured Boolean   @default(false)

  totalTrainers Int @default(0)
  totalBranches Int @default(1)

  gstNumber     String?
  licenseNumber String?

  password String

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  membershipPlans MembershipPlan[]
  users           User[]
  attendanceSessions AttendanceSession[]
  notices         Notice[]

  attendances Attendance[]
  conversations    Conversation[]
  chatParticipants Participant[]
  lastSeen         DateTime?
  isOnline         Boolean @default(false)
  passwordResetRequests PasswordResetRequest[]
  auditLogs             AuditLog[]
}

model UserMembershipPlans {
  id String @id @default(uuid())

  userId String

  user User @relation("UserMembershipHistory", fields: [userId], references: [id], onDelete: Cascade)

  membershipPlan MembershipPlan @relation(fields: [membershipPlanId], references: [id], onDelete: Cascade)

  membershipPlanId String

  planName         String
  price            Decimal? @db.Decimal(10, 2)
  currency         String   @default("INR")
  durationInMonths Int

  startDate DateTime
  endDate   DateTime

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  currentUsers User[] @relation("CurrentMembership")
}

model MembershipPlan {
  id    String @id @default(uuid())
  gymId String
  gym   Gym    @relation(fields: [gymId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text

  price           Decimal  @db.Decimal(10, 2)
  discountedPrice Decimal? @db.Decimal(10, 2)
  currency        String   @default("INR")

  durationInMonths Int

  features String[]

  isActive  Boolean @default(true)
  isPopular Boolean @default(false)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // users               User[]
  userMembershipPlans UserMembershipPlans[]

  @@unique([gymId, name])
  @@index([gymId])
  @@index([isActive])
  @@index([isPopular])
}


model AttendanceSession {
  id String @id @default(uuid())

  gymId String
  gym Gym @relation(fields: [gymId], references: [id])

  sessionCode String @unique

  isActive Boolean @default(true)

  startedAt DateTime @default(now())

  endedAt DateTime?

  createdBy String
  qrToken String?
  lastQrRefreshAt DateTime?

  attendanceRecords Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId,isActive])
}


model Attendance {
  id String @id @default(uuid())

  userId String
  user User @relation(fields:[userId], references:[id])

  gymId String
  gym Gym @relation(fields:[gymId], references:[id])

  attendanceSessionId String
  attendanceSession AttendanceSession @relation(fields:[attendanceSessionId], references:[id])

  checkInTime DateTime @default(now())

  attendanceDate DateTime

  method AttendanceMethod

  manualEntryReason String?

  createdAt DateTime @default(now())

  @@unique([userId,attendanceDate])

  @@index([gymId])
  @@index([attendanceDate])
}

enum AttendanceMethod {
  QR
  MANUAL
}

// =========================================================================
// Real-Time Chat & Communication Module
// =========================================================================

enum ConversationType {
  PRIVATE
  GROUP
}

enum SenderType {
  USER
  GYM
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  VOICE
  DOCUMENT
}

model Conversation {
  id             String           @id @default(uuid())
  gymId          String
  gym            Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  type           ConversationType
  isDefaultGroup Boolean          @default(false)
  title          String?          // e.g. "LEO Fitness Group" (only for GROUP)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  
  participants   Participant[]
  messages       Message[]

  @@index([gymId])
  @@index([type])
}

model Participant {
  id                     String       @id @default(uuid())
  conversationId         String
  conversation           Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  // A participant is either a User (member) or Gym (admin)
  userId                 String?
  user                   User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  gymId                  String?
  gym                    Gym?         @relation(fields: [gymId], references: [id], onDelete: Cascade)
  
  joinedAt               DateTime     @default(now())
  
  // Read and Delivery receipt markers
  lastReadMessageId      String?
  lastReadMessage        Message?     @relation("ReadReceipts", fields: [lastReadMessageId], references: [id])
  lastDeliveredMessageId String?
  lastDeliveredMessage   Message?     @relation("DeliveryReceipts", fields: [lastDeliveredMessageId], references: [id])
  
  unreadCount            Int          @default(0)
  deletedMessageIds      String[]     @default([])

  @@unique([conversationId, userId])
  @@unique([conversationId, gymId])
  @@index([userId])
  @@index([gymId])
  @@index([conversationId])
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType     SenderType
  senderId       String        // Points to either User.id or Gym.id
  text           String?       @db.Text
  type           MessageType   @default(TEXT)
  duration       String?       // For voice/video duration (e.g. "0:14")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  timestamp      DateTime      @default(now())

  attachments    Attachment[]
  
  // Receipts relations
  readByParticipants      Participant[] @relation("ReadReceipts")
  deliveredToParticipants Participant[] @relation("DeliveryReceipts")

  isDeleted      Boolean       @default(false)
  deletedBy      String?

  @@index([conversationId])
  @@index([createdAt])
  @@index([timestamp])
}

model Attachment {
  id           String   @id @default(uuid())
  messageId    String
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url          String   // Public/Signed S3 URL
  key          String?
  fileName     String
  fileSize     Int      // In bytes
  mimeType     String
  duration     String?  // e.g. "0:14"
  thumbnailUrl String?  // Optional generated thumbnail url for images/videos
  createdAt    DateTime @default(now())

  @@index([messageId])
}

model Notice {
  id        String   @id @default(uuid())
  title     String
  message   String   @db.Text
  startDate DateTime
  endDate   DateTime
  gymId     String?
  gym       Gym?     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gymId])
  @@index([startDate, endDate])
}

model WeightLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight    Float
  loggedAt  DateTime @default(now())

  @@index([userId])
  @@index([loggedAt])
}

model TargetLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  target    Float
  loggedAt  DateTime @default(now())

  @@index([userId])
  @@index([loggedAt])
}

model PasswordResetRequest {
  id          String   @id @default(uuid())
  adminId     String?
  admin       Gym?     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  email       String
  otpHash     String
  expiresAt   DateTime
  attempts    Int      @default(0)
  resendCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String?
  admin      Gym?     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action     String
  ipAddress  String?
  deviceInfo String?
  createdAt  DateTime @default(now())

  @@index([adminId])
}

model Session {
  id         String   @id @default(uuid())
  userId     String   // Maps to Gym.id or User.id
  role       String   // 'GYM_OWNER' or 'USER'
  deviceName String   @default("Unknown Device")
  deviceType String   @default("UNKNOWN") // 'ANDROID', 'IOS', 'WEB', 'DESKTOP'
  ipAddress  String?
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
}